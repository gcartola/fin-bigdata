# Fin BigData — exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# Nunca suba o arquivo .env para o GitHub.

# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=seu-projeto-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Dremio via PAT do próprio usuário
DREMIO_HOST=https://dremio.empresa.com
DREMIO_PAT=seu_pat_aqui

# Opcional: Dremio Cloud
DREMIO_PROJECT_ID=

# Opcional: GCS via DuckDB httpfs/HMAC
GCS_HMAC_KEY_ID=
GCS_HMAC_SECRET=

# Diretórios locais usados pelo projeto
DATA_DIR=./data
EXPORTS_DIR=./exports
LOGS_DIR=./logs
TMP_DIR=./tmp
